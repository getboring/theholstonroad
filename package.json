{
	"name": "theholstonroad",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"seo:generate": "tsx scripts/generate-seo-assets.ts",
		"build": "pnpm seo:generate && vite build",
		"preview": "npm run build && vite preview",
		"test": "vitest run",
		"deploy": "npm run build && node scripts/patch-worker-entry.js && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"db:seed": "tsx src/db/seeds/runner.ts",
		"patch-worker": "node scripts/patch-worker-entry.js"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.26.0",
		"@hookform/resolvers": "^5.2.2",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-query": "^5.100.1",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"better-auth": "^1.6.9",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.2",
		"immer": "^11.1.4",
		"lucide-react": "^0.545.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.73.1",
		"tailwindcss": "^4.1.18",
		"ulidx": "^2.4.1",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@cloudflare/vitest-pool-workers": "^0.15.0",
		"@rsbuild/core": "^2.0.1",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"better-sqlite3": "^12.9.0",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^28.1.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.2",
		"vite": "^8.0.0",
		"vitest": "^3.0.5",
		"wrangler": "^4.85.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	}
}
